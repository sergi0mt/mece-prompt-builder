# Copy this to .env and fill in your API keys.
# Get OpenRouter key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Web search providers (optional but recommended for Stage 2)
# Get Brave key at https://brave.com/search/api/
# Get Tavily key at https://tavily.com/
BRAVE_API_KEY=
TAVILY_API_KEY=
SEARCH_PROVIDER=auto

# Optional model overrides (defaults are good)
# MODEL_FAST=deepseek/deepseek-v3.2
# MODEL_BALANCED=google/gemini-2.5-flash
